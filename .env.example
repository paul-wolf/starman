# Copy to .env and adjust for your environment

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — store outside the project so rsync deployments never touch it
DB_PATH=/var/lib/starman/db.sqlite3

# Dish gRPC endpoint
DISH_GRPC_TARGET=192.168.100.1:9200

# How long a manual GPS inhibit holds off the watchdog (seconds)
WATCHDOG_MANUAL_OVERRIDE_GRACE_S=1800
